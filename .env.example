DISCORD_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=your-guild-id
DISCORD_PARENT_CATEGORY_ID=
DISCORD_FORUM_CHANNEL_ID=
DATABASE_PATH=./data/bountyops.sqlite3
STORAGE_DIR=./storage
DISCORD_WORKSPACE_MODE=category
HACKERONE_USERNAME=
HACKERONE_API_TOKEN=

# --- AI auto-run (/ai run) ---
# Engine for /ai run. Currently only "claude" is supported.
AI_ENGINE=claude
# Path to claude.exe. Leave empty to auto-detect the desktop-app install
# (%APPDATA%\Claude\claude-code\<version>\claude.exe).
CLAUDE_BIN=
# Long-lived token from `claude setup-token` (uses your Claude subscription, no API key).
CLAUDE_CODE_OAUTH_TOKEN=
# Max seconds to wait for one analysis run (Discord allows ~15 min).
AI_TIMEOUT_SECONDS=600

# --- Scope auto re-scan (/import refresh) ---
# How often the bot re-scans imported platform scope. 0 disables the weekly loop.
SCOPE_REFRESH_DAYS=7
# Channel to post scope-change alerts to. Falls back to DISCORD_FORUM_CHANNEL_ID.
SCOPE_REFRESH_CHANNEL_ID=

# --- /recommend huntr ---
# Optional GitHub token (classic PAT, no scopes needed) to raise the API limit
# from 60/hr to 5000/hr. Without it, /recommend huntr is easily rate-limited.
GITHUB_TOKEN=
